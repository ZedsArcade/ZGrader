<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>{{ strings.report_title }} {{ submission.code }}</title>
<link rel="stylesheet" href="report.css">
</head>
<body>
  <header class="report-header">
    {% if business.logo_path %}
    <img class="logo" src="{{ business.logo_path | file_uri }}" alt="logo">
    {% endif %}
    <div class="business-info">
      <h1>{{ business.name }}</h1>
      {% if business.contact %}<p class="contact">{{ business.contact }}</p>{% endif %}
    </div>
    <div class="submission-info">
      <p><strong>{{ strings.submission_label }}</strong> {{ submission.code }}</p>
      <p><strong>{{ strings.date_label }}</strong> {{ submission.created_at.strftime('%Y-%m-%d') }}</p>
      {% if submission.client_email %}<p><strong>{{ strings.client_label }}</strong> {{ submission.client_email }}</p>{% endif %}
    </div>
  </header>

  <section class="card-identity">
    <h2>{{ card.card_name }}{% if card.foil %} {{ strings.foil_suffix }}{% endif %}</h2>
    <p>
      {{ card.game }}
      {%- if card.set_name %} &mdash; {{ card.set_name }}{% endif %}
      {%- if card.card_number %} &mdash; #{{ card.card_number }}{% endif %}
    </p>
  </section>

  <section class="scorecard">
    <h2>{{ strings.scorecard_title }} <span class="estimate-note">{{ strings.scorecard_note }}</span></h2>
    <table>
      <thead><tr><th>{{ strings.col_category }}</th><th>{{ strings.col_front }}</th><th>{{ strings.col_back }}</th><th>{{ strings.col_combined }}</th></tr></thead>
      <tbody>
        {% for row in scorecard %}
        <tr>
          <td class="category-name">
            {{ category_labels[row.category] }}
            {%- if row.category in lower_confidence_categories %} <span class="lower-confidence-badge">{{ strings.lower_confidence_badge }}</span>{% endif %}
          </td>
          <td>{{ '%.1f' % row.front_score if row.front_score is not none else '—' }}</td>
          <td>{{ '%.1f' % row.back_score if row.back_score is not none else '—' }}</td>
          <td class="combined-score">{{ '%.1f' % row.combined_score if row.combined_score is not none else '—' }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </section>

  <section class="annotated-images">
    <h2>{{ strings.annotated_scans_title }}</h2>
    {% for row in scorecard %}
    <div class="image-row">
      <h3>{{ category_labels[row.category] }}</h3>
      <div class="image-pair">
        {% if row.front_image %}<figure><img src="{{ row.front_image | file_uri }}"><figcaption>{{ strings.front_caption }}</figcaption></figure>{% endif %}
        {% if row.back_image %}<figure><img src="{{ row.back_image | file_uri }}"><figcaption>{{ strings.back_caption }}</figcaption></figure>{% endif %}
      </div>
    </div>
    {% endfor %}
  </section>

  <section class="comparison">
    <h2>{{ strings.comparison_title }}</h2>
    <p class="comparison-intro">{{ strings.comparison_intro }}</p>
    {% for category, comparisons in comparisons_by_category.items() %}
    <div class="comparison-category">
      <h3>{{ category_labels[category] }}</h3>
      <table>
        <thead><tr><th>{{ strings.col_company }}</th><th>{{ strings.col_assessment }}</th><th>{{ strings.col_notes }}</th></tr></thead>
        <tbody>
          {% for comp in comparisons %}
          <tr>
            <td>{{ comp.company.value }}</td>
            <td><span class="severity-badge severity-{{ comp.severity.value }}">{{ severity_labels[comp.severity.value] }}</span></td>
            <td>{{ comp.contention_note }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% endfor %}
  </section>

  <section class="limitations">
    <h2>{{ strings.limitations_title }}</h2>
    <ul>
      <li>{{ strings.limitation_1 }}</li>
      <li>{{ strings.limitation_2 }}</li>
      <li>{{ strings.limitation_3 }}</li>
    </ul>
  </section>

  <footer class="report-footer">
    <p>{{ disclaimer }}</p>
    <p class="meta">{{ strings.generated_label }} {{ generated_at.strftime('%Y-%m-%d %H:%M UTC') }}</p>
  </footer>
</body>
</html>

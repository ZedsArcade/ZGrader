# Copy this file to .env and fill in real values before running
# `docker compose up`. See docs/qa_checklist.md for the full setup walkthrough.

# --- Postgres ---
POSTGRES_USER=zgrader
POSTGRES_PASSWORD=change-me
POSTGRES_DB=zgrader

# --- Backend ---
# Generate a real random value, e.g.: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ZGRADER_SECRET_KEY=change-me-to-a-real-random-secret

# Host-side path the scanner software writes into (SMB/NFS mount point, or
# a local folder). Mounted into both `backend` and `worker` at /data/scans.
SCANS_HOST_PATH=./data/scans

# --- SMTP (submission-received / report-published notification emails) ---
# Defaults point at the bundled `mailhog` dev service (docker compose --profile dev up),
# which catches mail locally with a web UI at http://localhost:8025 instead of
# actually sending anywhere. Point these at a real relay for production.
ZGRADER_SMTP_HOST=mailhog
ZGRADER_SMTP_PORT=1025
ZGRADER_SMTP_USER=
ZGRADER_SMTP_PASSWORD=
ZGRADER_SMTP_FROM=noreply@zgrader.local
ZGRADER_SMTP_USE_TLS=false
